[node name="npc_mara" type="CharacterBody2D"]
scale = Vector2(4, 4)
script = ExtResource("2_npc")
NpcName = "Old Mara"
Role = 0
DialogueLines = PackedStringArray("Mind your step, traveller — these woods have moods of their own.", "I'm Mara. I tend the herbs and the wounded.", "The miller's been coughing for three nights now. I need wild herbs to brew his tonic.", "Bring me six and I'll make it worth your while.")
QuestId = "herbalists_request"
modulate = Color(0.78, 0.95, 0.72, 1)

