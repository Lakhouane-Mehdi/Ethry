NpcName = "Mike"
Role = 1
DialogueLines = PackedStringArray("Welcome to the smithy! I'm Mike, the blacksmith.", "I forge the finest weapons and armor in all of Ethry.", "Bring me ingots and I'll craft something special for you.", "Need ore? You can find it in the caves deeper in the forest.", "I also sell tools and materials if you're in a pinch.")
