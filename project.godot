; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Game"
run/main_scene="uid://dvwccoys3wxdv"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ItemDatabase="*res://scripts/data/ItemDatabase.cs"
Inventory="*res://scripts/systems/Inventory.cs"
SceneTransition="*res://scripts/systems/SceneTransition.cs"
Equipment="*res://scripts/systems/Equipment.cs"
NotificationManager="*res://scripts/systems/NotificationManager.cs"
PlayerData="*res://scripts/systems/PlayerData.cs"
DaySystem="*res://scripts/systems/DaySystem.cs"
GameHUD="*res://scripts/ui/GameHUD.cs"
SaveSystem="*res://scripts/systems/SaveSystem.cs"
PauseMenu="*res://scripts/ui/PauseMenu.cs"
StorageUI="*res://scenes/ui/storage_ui.tscn"
AudioManager="*res://scenes/systems/audio_manager.tscn"
EffectsManager="*res://scripts/systems/EffectsManager.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
gui/common/snap_controls_to_pixels=true

[dotnet]

project/assembly_name="The Game"

